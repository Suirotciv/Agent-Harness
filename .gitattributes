# Enforce LF line endings in the repo regardless of core.autocrlf
* text=auto eol=lf
*.py text eol=lf
*.md text eol=lf
*.yaml text eol=lf
*.yml text eol=lf
*.toml text eol=lf
*.json text eol=lf
*.txt text eol=lf
*.cfg text eol=lf
*.ini text eol=lf
*.editorconfig text eol=lf

# Binary files -- no line ending conversion
*.png binary
*.jpg binary
*.jpeg binary
*.pdf binary
*.ico binary